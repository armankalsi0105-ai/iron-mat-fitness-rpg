# IronPath AI Coach Environment Variables
# Go to https://aistudio.google.com/app/apikey to get a valid API Key.
# A valid Google AI Studio key should start with "AIza..."

# Server-side key (used by Express API routes — not exposed to the browser)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: set a custom key per-browser via Settings (Sliders icon in the app header)
